# Dashboard connection
DASHBOARD_URL=https://nnunet-dashboard-1.apps.myphysics.net
DASHBOARD_API_KEY=changeme

# Notifications (optional — leave blank to disable)
GOOGLE_CHAT_WEBHOOK_URL=

# Worker identity (shown in dashboard Workers tab)
WORKER_NAME=worker-slurm01
WORKER_HOSTNAME=nvwulf.example.com
GPU_NAME=RTX Pro 6000 Blackwell
GPU_MEMORY_GB=48.0
CPU_CORES=16
SYSTEM_MEMORY_GB=128.0

# Timing
POLL_INTERVAL_S=30
HEARTBEAT_INTERVAL_S=60

# Paths
DATA_DIR=/lustre/nvwulf/scratch/jinkokim/data/nnunet-data
CONDA_ENV=nvwulf_scripts

# SLURM — preprocessing (CPU-only, no GPU requested)
SLURM_PARTITION_PREPROCESS=b40x4
SLURM_CPUS_PREPROCESS=16
SLURM_MEM_PREPROCESS=128G
SLURM_TIME_PREPROCESS=8:00:00

# SLURM — training (GPU job)
SLURM_PARTITION_TRAIN=b40x4-long
SLURM_CPUS_TRAIN=16
SLURM_MEM_TRAIN=128G
SLURM_TIME_TRAIN=2-00:00:00
SLURM_GPUS_TRAIN=1

# SLURM email (optional — leave blank to disable)
SLURM_MAIL_USER=jinkoo.kim@stonybrook.edu
SLURM_MAIL_TYPE=ALL

# nnUNet settings
NUM_PREPROCESSING_WORKERS=16
